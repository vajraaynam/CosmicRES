[Desktop Entry]
Name=Resource Monitor
Comment=A resource monitor applet for the COSMIC desktop
Type=Application
Icon=com.github.pop-os.cosmic-resource-monitor
Exec=cosmic-resource-monitor %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC;Monitor;CPU;RAM;Disk;Resources
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
